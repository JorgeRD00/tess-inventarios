{
  "name": "moto-inventario-tauri",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx -r tsconfig-paths/register src/server.ts",
    "start": "npx prisma db push --accept-data-loss --skip-generate && npx prisma db seed && npx tsx -r tsconfig-paths/register src/server.ts",
    "postinstall": "npx prisma generate",
    "tauri": "tauri"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@tauri-apps/api": "^1.5.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "prisma": "^5.7.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
