# URL de conexión a PostgreSQL (obtenida de Supabase > Project Settings > Database)
# Reemplaza los valores entre < > con los tuyos.
# El formato es:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Puerto en el que corre el backend (Render lo sobreescribe con su variable PORT)
PORT=3000
