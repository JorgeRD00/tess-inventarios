{
  "name": "tess-inventario",
  "version": "1.0.0",
  "description": "Sistema profesional de inventario para tienda de refacciones hecho por TESS",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run frontend-dev\" \"npm run backend-dev\"",
    "build": "npm run tauri build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "frontend-dev": "powershell -Command \"Start-Sleep -s 2; vite\"",
    "frontend-build": "vite build",
    "frontend-preview": "vite preview",
    "backend-dev": "npm --prefix src-tauri run dev",
    "prisma:generate": "cd src-tauri && npx prisma generate",
    "prisma:migrate": "cd src-tauri && npx prisma migrate dev",
    "prisma:studio": "cd src-tauri && npx prisma studio",
    "prisma:seed": "cd src-tauri && npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  }
}
